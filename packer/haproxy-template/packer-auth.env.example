#!/usr/bin/env bash
# Copy to packer-auth.env, fill in real values, then source it directly
# or use ../../load-env.sh from the repo root.

export PKR_VAR_vcenter_password="CHANGE_ME"
export PKR_VAR_ssh_password="CHANGE_ME"

# Optional: if you want to keep usernames/servers out of var files too
# export PKR_VAR_vcenter_server="192.168.1.10"
# export PKR_VAR_vcenter_username="administrator@vsphere.local"
# export PKR_VAR_ssh_username="root"
