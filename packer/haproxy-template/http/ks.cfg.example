#version=RHEL9
text
cdrom
lang en_US.UTF-8
keyboard us
timezone UTC --utc
network --bootproto=dhcp --device=link --activate
rootpw --plaintext ChangeMe123!
firewall --enabled --service=ssh
selinux --enforcing
firstboot --disable
services --enabled="sshd,NetworkManager,vmtoolsd"
bootloader --location=mbr
zerombr
clearpart --all --initlabel
autopart --type=lvm
reboot

%packages
@^minimal-environment
openssh-server
open-vm-tools
cloud-init
qemu-guest-agent
%end

%post --log=/root/ks-post.log
systemctl enable sshd
systemctl enable vmtoolsd
systemctl enable qemu-guest-agent
echo "packer" > /etc/hostname
mkdir -p /etc/ssh/sshd_config.d
cat > /etc/ssh/sshd_config.d/99-packer.conf <<'EOF'
PermitRootLogin yes
PasswordAuthentication yes
EOF
mkdir -p /etc/cloud/cloud.cfg.d
cat > /etc/cloud/cloud.cfg.d/99-packer.cfg <<'EOF'
disable_root: false
ssh_pwauth: true
EOF
%end
