#!/usr/bin/env bash
# Copy to okd-template.env and adjust values.

export GOVC_URL="https://vcenter.example.local"
export GOVC_USERNAME="administrator@vsphere.local"
export GOVC_PASSWORD="CHANGE_ME"
export GOVC_INSECURE="1"
export GOVC_DATACENTER="LabDatacenter"

# Datastore and network for template import
export DATASTORE="VMs"
export NETWORK_NAME="VM Network"

# Existing OVA path on control host
export OVA_LOCAL_PATH="/mnt/hgfs/OK_Project/OS/fedora-coreos-39.20231101.3.0-vmware.x86_64.ova"

# Target VM/template names
export IMPORT_VM_NAME="fcos-tmp-build"
export TEMPLATE_NAME="fedora-coreos-39.20231101.3.0"

# Optional VM folder (empty = root)
export VM_FOLDER="OKD"
