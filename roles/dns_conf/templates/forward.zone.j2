; Forward zone file for {{ network.domain }}
; Generated by Ansible DNS role
$TTL 86400
@ IN SOA {{ dns_infra.dns_server.hostname }}. admin.{{ network.domain }}. (
  {{ ansible_date_time.epoch }} ; serial
  3600 ; refresh
  1800 ; retry
  1209600 ; expire
  86400 ; minimum
)

; Name server
@ IN NS {{ dns_infra.dns_server.hostname }}.

; Infrastructure hosts
{{ dns_infra.dns_server.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ dns_infra.dns_server.ip }}
{{ dns_infra.nfs_server.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ dns_infra.nfs_server.ip }}
{{ dns_infra.ansible_server.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ dns_infra.ansible_server.ip }}
{{ dns_infra.ad_server.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ dns_infra.ad_server.ip }}
{{ dns_infra.haproxy_server.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ dns_infra.haproxy_server.ip }}
{{ dns_infra.vcenter.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ dns_infra.vcenter.ip }}

; ESXi hosts
{% for esxi in dns_esxi_records %}
{{ esxi.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ esxi.ip }}
{% endfor %}

; Load Balancer VIPs
{% for vip in dns_infra.load_balancer_vips | default([]) %}
{{ vip.name | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ vip.ip }}
{% endfor %}

; Bootstrap / control-plane / workers
{% if dns_infra.bootstrap is defined %}
{{ dns_infra.bootstrap.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ dns_infra.bootstrap.ip }}
{% endif %}
{% for master in dns_infra.master | default([]) %}
{{ master.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ master.ip }}
{% endfor %}
{% for worker in dns_infra.worker | default([]) %}
{{ worker.hostname | regex_replace('\\.' + network.domain + '$', '') }} IN A {{ worker.ip }}
{% endfor %}

