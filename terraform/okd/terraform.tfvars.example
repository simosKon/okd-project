# vSphere credentials (set password via env var: TF_VAR_vsphere_password)
# export TF_VAR_vsphere_password='YOUR_REAL_PASSWORD'
vsphere_user   = "administrator@vsphere.local"
vsphere_server = "vcenter.example.local"

# vSphere inventory
datacenter    = "LabDatacenter"
cluster       = "OKD"
datastore     = "vsanDatastore"
network       = "VM Network"
template_name = "fedora-coreos-39.20231101.3.0"

# ignition artifacts generated by 02_okd_upi_prepare.yml
bootstrap_ignition_b64_file = "/root/okd-install/bootstrap.64"
master_ignition_b64_file    = "/root/okd-install/master.64"
worker_ignition_b64_file    = "/root/okd-install/worker.64"

# node naming + MACs (for DHCP reservations)
bootstrap_mac_address = "00:50:56:ad:d0:c5"
masters = [
  { name = "master01", mac_address = "00:50:56:ad:90:fd" },
  { name = "master02", mac_address = "00:50:56:ad:40:2a" },
  { name = "master03", mac_address = "00:50:56:ad:17:f6" }
]
workers = [
  { name = "worker01", mac_address = "00:50:56:ad:22:b0" }
]

# optional tuning
vm_folder = "OKD"
bootstrap_cpu       = 4
bootstrap_memory_mb = 12288
bootstrap_disk_size_gb = 60
bootstrap_to_nodes_delay_seconds = 120
master_cpu          = 4
master_memory_mb    = 12288
master_disk_size_gb = 120
worker_cpu          = 4
worker_memory_mb    = 12288
worker_disk_size_gb = 120
